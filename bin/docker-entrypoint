#!/bin/bash
set -e

# 1. Remove a stale server.pid if it exists (prevents boot errors)
rm -f /rails/tmp/pids/server.pid

# 2. If we are starting the server, prepare the SQLite database
# This creates the production.sqlite3 file and runs migrations
if [ "$1" = "./bin/thrust" ]; then
  ./bin/rails db:prepare
fi

# 3. Execute the command provided to the container (the CMD from Dockerfile)
exec "$@"
