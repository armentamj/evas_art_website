erb
<div class="mx-auto md:w-2/3 w-full">
  <%# 1. Flash Alerts (e.g., "Link Expired") %>
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Update your password</h1>

  <%# 2. Validation Errors (e.g., "Passwords don't match") %>
  <% if @user&.errors&.any? %>
    <div class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-5">
      <h2 class="font-bold"><%= pluralize(@user.errors.count, "error") %> stopped this save:</h2>
      <ul class="list-disc ml-5">
        <% @user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# 3. The Form (Using scope: :user to wrap params correctly) %>
  <%= form_with url: password_path(params[:token]), method: :patch, scope: :user, class: "contents" do |form| %>  
    <div class="my-5">
      <%= form.label :password, "New Password", class: "block font-medium" %>
      <%= form.password_field :password, 
          required: true, 
          autofocus: true,
          autocomplete: "new-password", 
          placeholder: "Enter new password", 
          maxlength: 72, 
          class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>
    <div class="my-5">
      <%= form.label :password_confirmation, "Repeat New Password", class: "block font-medium" %>
      <%= form.password_field :password_confirmation, 
          required: true, 
          autocomplete: "new-password", 
          placeholder: "Repeat new password", 
          maxlength: 72, 
          class: "block shadow-sm rounded-md border border-gray-400 focus:outline-solid focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
    </div>
    <div class="inline">
      <%= form.submit "Save New Password", 
          class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    </div>

  <% end %>
</div>