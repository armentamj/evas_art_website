<%# This is for seo purposes %>
<% title "Contact" %>
<% description "Email Eva Armenta" %>

<div class="flex flex-col items-center w-11/12 md:w-2/3 lg:w-1/3 mt-10 mx-auto border border-black bg-blue-50 p-2 rounded-xl shadow-xl">
  
  <h1 class="font-semibold text-xl mb-8 text-center">
    <%= t('instruction', email: 'evaarmentaart@gmail.com') %>
  </h1>

  <div class="w-full max-w-lg flex flex-col gap-6">
    <div class="flex flex-col justify-between gap-2">
      <%= label_tag :subject, t('subject_label'), class: "font-semibold" %>
      <input type="text" id="subject" required class="bg-white border border-black rounded-lg px-3 py-2 outline-none focus:ring-2 focus:ring-pink-700">
    </div>

    <div class="flex flex-col justify-between gap-2">
      <%= label_tag :message, t('message_label'), class: "font-semibold" %>
      <textarea id="message" required class="bg-white border border-black rounded-lg px-3 py-2 h-40 outline-none focus:ring-2 focus:ring-pink-700"></textarea>
    </div>

    <div class="flex justify-center mt-4">
      <button type="button" onclick="sendMail()" class="shadow-lg bg-white cursor-pointer hover:text-white border border-black/30 px-2 py-1 text-black transition font-bold rounded-md hover:bg-pink-700">
        <%= t('submit_button') %>
      </button>
    </div>
  </div>
</div>

<script>
  function sendMail() {
    const email = "evaarmentaart@gmail.com";
    const subject = document.getElementById('subject').value;
    const body = document.getElementById('message').value;

    // Construct the mailto URL correctly with ? and &
    const mailtoUrl = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    
    window.location.href = mailtoUrl;
  }
</script>
