<%# app/views/contact/index.html.erb %>

<div class="flex flex-col items-center w-11/12 md:w-2/3 lg:w-1/3 mt-10 mx-auto border border-black bg-blue-50 p-2 rounded-xl">
  
  <p class="font-semibold text-xl mb-8 text-center">
    <%= t('instruction', email: 'evaarmentaart@gmail.com') %>
  </p>

  <%# The JS onsubmit grabs the values from the IDs and opens the user's local mail client %>
  <%= form_with url: "#", method: :get, local: true, class: "w-full max-w-lg flex flex-col gap-6", html: { 
      onsubmit: "window.location.href='mailto:evaarmentaart@://gmail.com' + encodeURIComponent(document.getElementById('subject').value) + '&body=' + encodeURIComponent(document.getElementById('message').value); return false;" 
    } do |f| %>
    
    <div class="flex flex-col justify-between gap-2">
      <%= label_tag :subject, t('subject_label'), class: "font-semibold min-w-[100px]" %>
      <%= text_field_tag :subject, nil, id: 'subject', required: true, class: "bg-white border border-black rounded-lg px-3 py-2 flex-grow focus:ring-2 focus:ring-pink-700 outline-none" %>
    </div>

    <div class="flex flex-col justify-between gap-2">
      <%= label_tag :message, t('message_label'), class: "font-semibold min-w-[100px]" %>
      <%= text_area_tag :message, nil, id: 'message', required: true, class: "bg-white border border-black rounded-lg px-3 py-2 flex-grow h-40 focus:ring-2 focus:ring-pink-700 outline-none" %>
    </div>

    <div class="flex justify-center mt-4">
      <%= f.submit t('submit_button'), class: "bg-white cursor-pointer hover:text-white border border-black px-6 py-2 text-black transition font-bold rounded-md hover:bg-pink-700" %>
    </div>

  <% end %>
</div>
