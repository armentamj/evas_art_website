<%# This is for seo purposes %>
<% title "Impressum" %>
<% description "Legal information and contact details." %>

<div class="max-w-3xl mx-auto px-4 py-12">
  <h1 class="text-4xl font-bold mb-8"><%= t('impressum_title') %></h1>

  <h2 class="text-xl font-semibold mb-4"><%= t('impressum_section_info') %></h2>
  <p><strong><%= t('impressum_owner') %>:</strong> Eva Armenta</p>

  <h2 class="text-xl font-semibold mt-8 mb-4"><%= t('impressum_contact') %></h2>
  <p><strong><%= t('impressum_email') %>: </strong>evaarmentaart@gmail.de</p>

  <h2 class="text-xl font-semibold mt-8 mb-2"><%= t('impressum_disclaimer_title') %></h2>
