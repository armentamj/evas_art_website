<!DOCTYPE html>
<html class="w-full flex flex-col justify-start items-center">
  <head>
    <title><%= content_for(:title) || "Evas Art Website" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <!-- Replace your current cdnjs link with this one -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com"
    integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Maven+Pro:wght@400..900&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest ... (keep or comment as-is) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Tailwind here -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>
  </head>
  <body class="mt-20 md:mt-35 w-full h-fit flex flex-col justify-start items-center">
    <%= render "layouts/navbar" %>
    <main class="h-fit w-full flex flex-col justify-start items-center">
      <%= yield %>
    </main>
  </body>
</html>
