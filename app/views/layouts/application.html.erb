<!DOCTYPE html>
<html class="w-screen flex flex-col justify-start items-center">
  <head class="relative">
    <title><%= content_for(:title) || "Evas Art Website" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com" 
      integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" 
      crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Maven+Pro:wght@400..900&display=swap" rel="stylesheet">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <nav class="navi fixed top-0 left-0 h-20 md:h-20 lg:h-28 w-full p-6 flex justify-between items-end flex-col md:flex-col lg:flex-row bg-blue-500 z-[2]">
      <button id="menu-btn" class="block lg:hidden text-2xl focus:outline-none cursor-pointer text-black absolute top-25 left-10">
        <i id="menu-icon" class="fa-solid fa-xmark"></i>
        <i id="x-icon" class="fa-solid fa-bars hidden"></i>
      </button>
      <!-- Left side are the auth-dependent links -->
      <div class="hidden flex lg:flex flex-col lg-flex-row items-center">
        <% if authenticated? %>
          <%= link_to "New Artwork", new_artwork_path, class: "px-2 py-1 text-black transition font-bold rounded-md hover:bg-pink-700" %>
        <% end %>
      </div>
      <h1 class="text-black absolute left-1/2 -translate-x-1/2 font-bold text-2xl md:text-4xl">EVA ARMENTA</h1>
      <!-- Right side - only visible from lg and up -->
      <div class="hidden flex lg:flex flex-col lg:flex-row items-center gap-4">
        <%= form_with url: artworks_path, method: :get, class: "flex items-center gap-2" do |f| %>
          <%= f.text_field :id, placeholder: "ID#...",
                class: "px-4 py-2 rounded-md border border-gray-300 bg-white focus:outline-none focus:ring-2 focus:ring-pink-500 text-gray-900 w-20",
                required: true, pattern: "\\d+" %>
          <%= f.submit "Search", class: "px-2 py-1 text-black rounded-md hover:bg-pink-700 transition font-bold" %>
        <% end %>
        <% if authenticated? %>
          <%= button_to "Sign Out", session_path, method: :delete, class: " px-2 py-1 text-black transition font-bold rounded-md hover:bg-pink-700" %>
        <% else %>
          <%= button_to "Sign In", session_path, method: :delete, class: "px-2 py-1 text-black transition font-bold rounded-md hover:bg-pink-700" %>
        <% end %>
        <%= link_to "Home", root_path, class: "px-2 py-1 text-black transition font-bold rounded-md hover:bg-pink-700" %>
      </div>
    </nav>
    <%= yield :head %>

    <%# Enable PWA manifest ... (keep or comment as-is) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Tailwind here -->
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>

    <%= javascript_importmap_tags %>
  </head>
  <body class="mt-20 lg:mt-35 w-full h-fit flex flex-col justify-start items-center">
    <main class="h-fit w-full flex flex-col justify-start items-center pt-5">
      <%= yield %>
    </main>
  </body>
</html>
