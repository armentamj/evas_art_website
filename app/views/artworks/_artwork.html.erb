<div id="<%= dom_id artwork %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= artwork.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= artwork.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Price:</strong>
    <%= artwork.price %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Category:</strong>
    <%= artwork.category %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Size:</strong>
    <%= artwork.size %>
  </div>
</div>
