<div class="w-fit mx-auto bg-blue-50 rounded-xl shadow-lg p-4">
  <h1 class="text-2xl md:text-3xl mb-0 md:mb-6 text-gray-900 uppercase"><%= artwork.title %></h1>
  <% if artwork.images.attached? %>
    <!-- Carousel Container -->
    <div class="relative group">
      <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-4 rounded-xl">
        <% artwork.images.each do |image| %>
          <div class="flex-none w-full snap-center flex justify-center">
            <%= image_tag image, class: "w-300 h-[300px] md:h-[500px] object-contain" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="mt-2 border-t pt-2 md:pt-6">
    <p class="text-black"><%= artwork.description %></p>
    <p class="text-black"><%= t('size') %> <%= artwork.size %></p>
    <p class="text-black"><%= t('id_number') %> <%= artwork.id %></p>
    <p class="text-2xl font-semibold">€<%= number_with_precision(artwork.price, precision: 0) %></p>
  </div>
</div>
