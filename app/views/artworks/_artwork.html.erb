<div id="<%= dom_id artwork %>" class="max-w-4xl mx-auto bg-blue-50 p-6 rounded-xl shadow-lg">
  <h1 class="text-3xl font-serif mb-6 text-gray-900 uppercase"><%= artwork.title %></h1>
  <% if artwork.images.attached? %>
    <!-- Carousel Container -->
    <div class="relative group">
      <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-4 rounded-xl">
        <% artwork.images.each do |image| %>
          <div class="flex-none w-full snap-center">
            <%= image_tag image, class: "w-full h-[500px] object-contain rounded-lg" %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="mt-8 border-t pt-6">
    <p class="text-black"><%= artwork.description.capitalize %></p>
    <p class="text-black">Size: <%= artwork.size %></p>
    <p class="text-2xl font-semibold">€<%= number_with_precision(artwork.price, precision: 0) %></p>
  </div>
</div>
