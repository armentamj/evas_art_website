<div class="relative mt-5 px-4">
  <% if notice.present? %>
    <p class="py-1 px-2 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <%= render @artwork %>

  <% 
    # Prepare the email body lines using your YAML keys
    mail_body_lines = [
      t('greeting'),
      "",
      t('interest'),
      "",
      "#{t('name')}: #{@artwork.title}",
      "#{t('id')}: #{@artwork.id}",
      "#{t('price')}: #{number_to_currency(@artwork.price)}",
      "",
      t('payment_request'),
      "",
      t('closing')
    ]

    # Encode for mailto (ensuring spaces are %20 and not +)
    subject_encoded = ERB::Util.url_encode(t('subject', title: @artwork.title, id: @artwork.id))
    body_encoded    = ERB::Util.url_encode(mail_body_lines.join("\r\n"))

    mail_url = "mailto:evaarmentaart@://gmail.com{subject_encoded}&body=#{body_encoded}"
  %>

  <div class="flex justify-end items-center absolute bottom-5 right-5 z-10">
    <%= link_to t('purchase'), mail_url, class: "border border-black/10 mx-1 w-fit text-center rounded-md px-2 py-1 hover:bg-pink-500 inline-block shadow-lg bg-white font-medium hover:text-white" %>

    <% if authenticated? %>
      <%= link_to t('edit'), edit_artwork_path(@artwork), class: "border border-black/10 mx-1 w-fit text-center rounded-md px-2 py-1 hover:bg-pink-500 inline-block shadow-lg bg-white font-medium hover:text-white" %>
      <%= button_to t('delete'), @artwork, method: :delete, class: "border border-red-100 text-red-500 mx-1 w-fit text-center rounded-md px-2 py-1 hover:bg-pink-500 inline-block shadow-lg bg-white font-medium hover:text-white", data: { turbo_confirm: "Are you sure?" } %>
    <% end %>
  </div>
</div>

