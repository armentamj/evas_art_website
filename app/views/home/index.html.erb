      <% else %>
        <div class="w-9/10 aspect[9/16]"><p>The Category Flowers and Still Lifes is Currently Empty</p></div>
      <% end %>
      <h3>Flowers-and-Still-Lifes</h3>
    </div>
  <% end %>
  <%= link_to category_path("tiny-art") do %>
    <div class="w-9/10 aspect[9/16] home-cards">
      <% if @tiny_art_first&.photos&.any? %>
        <%= image_tag @tiny_art_first.photos.first.variant(resize_to_limit: [400,400]), alt: "Tiny-Art" %>
      <% else %>
        <div class="w-9/10 aspect[9/16]"><p>The Category Tiny Art is Cuurrently Empty</p></div>
      <% end %>
