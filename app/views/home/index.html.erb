<% content_for :head do %>
  <% if @hero_image_url %>
    <link rel="preload" as="image" href="<%= @hero_image_url %>" fetchpriority="high">
  <% end %>
<% end %>

<div class="w-full text-center flex flex-col justify-start items-center min-h-full">
  <div class="w-full flex flex-col justify-start items-center px-4">
    <h1 class="text-[clamp(24px,8vw,96px)] mt-4 lg:mt-20 font-semi-bold">EVA ARMENTA ART</h1>
    <p class="text-[clamp(15px,2vw,24px)] mt-4"><%= t('saying') %></p>
  </div>

  <div class="w-full max-w-7xl mx-auto py-12 flex flex-col items-center space-y-12 md:space-y-30">
    <!-- Abstract Paintings -->
    <div class="w-full max-w-[70%] aspect-[1/1] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("abstract-paintings") , class: "block w-full h-full" do %>
        <% if @abstract_paintings_first&.images&.attached? %>
          <%= image_tag @abstract_paintings_first.images.first.variant(resize_to_limit: [800, 800], format: :webp, saver: { quality: 80, strip: true }),
                        alt: t('abstract_painting'),
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 scale-165" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6"><%= t('category_is_empty') %></p>
          </div>
        <% end %>
        <h2 class="absolute left-1/2 -translate-x-1/2 md:translate-x-0 md:bottom-6 md:left-6 text-2xl md:text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          <%= t('abstract_paintings') %>
        </h2>
      <% end %>
    </div>

    <!-- Flowers and Still Lifes -->
    <div class="w-full max-w-[70%] aspect-[1/1] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("flowers-and-still-lifes"), class: "block w-full h-full" do %>
        <% if @flowers_and_still_lifes_first&.images&.attached? %>
          <%= image_tag @flowers_and_still_lifes_first.images.first.variant(resize_to_limit: [800, 800], format: :webp, saver: { quality: 80, strip: true }),
                        loading: "lazy", alt: t('flowers_and_still_lifes'),
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 scale-165" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6"><%= t('category_is_empty') %></p>
          </div>
        <% end %>
        <h2 class="absolute left-1/2 -translate-x-1/2 md:translate-x-0 md:bottom-6 md:left-6 text-2xl md:text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          <%= t('flowers_and_still_lifes') %>
        </h2>
      <% end %>
    </div>

    <!-- Tiny Art -->
    <div class="w-full max-w-[70%] aspect-[1/1] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("tiny-art"), class: "block w-full h-full" do %>
        <% if @tiny_art_first&.images&.attached? %>
          <%= image_tag @tiny_art_first.images.first.variant(resize_to_limit: [800, 800], format: :webp, saver: { quality: 80, strip: true }),
                        loading: "lazy", alt: t('tiny_art'),
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 scale-165" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6"><%= t('category_is_empty') %></p>
          </div>
        <% end %>
        <h2 class="absolute left-1/2 -translate-x-1/2 md:translate-x-0 md:bottom-6 md:left-6 text-2xl md:text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          <%= t('tiny_art') %>
        </h2>
      <% end %>
    </div>
  </div>
</div>