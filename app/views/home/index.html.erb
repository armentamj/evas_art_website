<div class="w-full text-center flex flex-col justify-start items-center min-h-full">
  <div class="w-full flex flex-col justify-start items-center px-4">
    <h1 class="text-[clamp(24px,8vw,96px)] mt-4 lg:mt-20 font-semi-bold">EVA ARMENTA ART</h1>
    <p class="text-[clamp(15px,2vw,24px)] mt-4">Modern, colorful, and bold abstract art and flowers.</p>
  </div>

  <div class="w-full max-w-7xl mx-auto py-12 flex flex-col items-center space-y-12 md:space-y-30">
    <!-- Abstract Paintings -->
    <div class="w-full max-w-[70%] aspect-[16/9] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("abstract-paintings"), class: "block w-full h-full" do %>
        <% if @abstract_paintings_first&.images&.attached? %>
          <%= image_tag @abstract_paintings_first.images.first.variant(resize_to_limit: [1200, nil]),
                        alt: "Abstract Paintings",
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 hover:scale-105" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6">Category is empty</p>
          </div>
        <% end %>
        <h3 class="absolute bottom-6 left-6 text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          Abstract Paintings
        </h3>
      <% end %>
    </div>

    <!-- Flowers and Still Lifes -->
    <div class="w-full max-w-[70%] aspect-[16/9] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("flowers-and-still-lifes"), class: "block w-full h-full" do %>
        <% if @flowers_and_still_lifes_first&.images&.attached? %>
          <%= image_tag @flowers_and_still_lifes_first.images.first.variant(resize_to_limit: [1200, nil]),
                        alt: "Flowers and Still Lifes",
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 hover:scale-105" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6">Category is empty</p>
          </div>
        <% end %>
        <h3 class="absolute bottom-6 left-6 text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          Flowers and Still Lifes
        </h3>
      <% end %>
    </div>

    <!-- Tiny Art -->
    <div class="w-full max-w-[70%] aspect-[16/9] border border-black-500 overflow-hidden rounded-lg shadow-lg relative">
      <%= link_to category_path("tiny-art"), class: "block w-full h-full" do %>
        <% if @tiny_art_first&.images&.attached? %>
          <%= image_tag @tiny_art_first.images.first.variant(resize_to_limit: [1200, nil]),
                        alt: "Tiny Art",
                        class: "absolute inset-0 w-full h-full object-cover transition-transform duration-300 hover:scale-105" %>
        <% else %>
          <div class="absolute inset-0 w-full h-full bg-gray-200 flex items-center justify-center">
            <p class="text-gray-600 text-2xl text-center px-6">Category is empty</p>
          </div>
        <% end %>
        <h3 class="absolute bottom-6 left-6 text-3xl md:text-4xl text-white drop-shadow-lg font-semibold">
          Tiny Art
        </h3>
      <% end %>
    </div>
  </div>
</div>