<div class="w-full text-center flex flex-col justify-start items-center bg-cover bg-center" 
     style="background-image: url('<%= asset_path('eva_header_image.jpg') %>')">
>
  <div class="w-full flex flex-col justify-start items-center">
    <h1 class="text-white text-8xl mt-40">EVA ARMENTA ART</h1>
    <p class="text-white">Modern, colorful, and bold abstract art and flowers.</p>
  </div>
  <div class="w-full flex flex-col justify-start items-center w-full">
    <%= link_to category_path("abstract-paintings") do %>
      <div class="w-90 aspect-[21/9] home-cards my-10 border border-black-500 self-end text-white">
        <%# Changed .any? to .attached? %>
        <% if @abstract_paintings_first&.images&.attached? %>
          <%= image_tag @abstract_paintings_first.images.first.variant(resize_to_limit: [400,400]), 
              alt: "Abstract Paintings", 
              class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full aspect-[21/9] flex items-center justify-center bg-gray-100">
            <p class="text-white text-2xl text-center">Category is empty.</p>
          </div>
        <% end %>
        <h3 class="text-2xl">Abstract Paintings</h3>
      </div>
    <% end %>
    <%# Flowers and Still Lifes Category %>
    <%= link_to category_path("flowers-and-still-lifes") do %>
      <div class="w-90 aspect-[21/9] home-cards my-10 border border-black-500 overflow-hidden flex flex-col text-white">
        <% if @flowers_and_still_lifes_first&.images&.attached? %>
          <%= image_tag @flowers_and_still_lifes_first.images.first.variant(resize_to_limit: [400, 400]), 
              alt: "Flowers and Still Lifes", 
              class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full bg-gray-100 flex items-center justify-center">
            <p class="text-white text-2xl text-center px-4">Category is empty.</p>
          </div>
        <% end %>
        <h3 class="text-2xl p-2 bg-white">Flowers and Still Lifes</h3>
      </div>
    <% end %>
    <%# Tiny Art Category %>
    <%= link_to category_path("tiny-art") do %>
      <div class="w-90 aspect-[21/9] home-cards my-10 border border-black-500 overflow-hidden flex flex-col text-white">
        <% if @tiny_art_first&.images&.attached? %>
          <%= image_tag @tiny_art_first.images.first.variant(resize_to_limit: [400, 400]), 
              alt: "Tiny Art", 
              class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full bg-gray-100 flex items-center justify-center">
            <p class="text-white text-2xl text-center px-4">Category is empty.</p>
          </div>
        <% end %>
        <h3 class="text-2xl p-2 bg-white">Tiny Art</h3>
      </div>
    <% end %>
  </div>
</div>
