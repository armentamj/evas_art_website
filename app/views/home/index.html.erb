<div class="Intro">
  <h1 class="font-bold text-4xl text-center">Eva Armenta Art</h1>
  <p>Find me in app/views/home/index.html.erb</p>
</div>
<div class="w-full flex-col justify-start items-center">
  <%= link_to category_path("abstarct-paintings") do %>
    <div class="w-9/10 aspect[9/16] home-cards">
      <% if  @abstract_paintings_first&.photos&.any? %>
        <%= image_tag  @abstract_paintings_first.photos.first.variant(resize_to_limit: [400,400]), alt: "Abstarct-Paintings" %>
      <% else %>
        <div class="w-9/10 aspect[9/16]"><p>The Category Abstract Paintings is Currently Empty</p></div>
      <% end %>
      <h3>Abstract Paintings</h3>
    </div>
  <% end %>
  <%= link_to category_path("flowers-and-still-lifes") do %>
    <div class="w-9/10 aspect[9/16] home-cards">
      <% if @flowers_and_still_lifes_first&.photos&.any? %>
